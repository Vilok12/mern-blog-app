### create user
POST http://localhost:3000/userapi/user
Content-Type: application/json

{
    "firstname":"vk",
    "lastname":"kumar",
    "email":"mvk1@gmail.com",
    "password":"123456",
    "profileimageurl":"http://google.com"

}

### common authenticate 
POST http://localhost:3000/commonapi/authenticate
Content-Type: application/json

{
    "email":"suuusvwfw112geuu@gmail.com",
    "password":"1234er5ss"
}



### change password
PUT http://localhost:3000/commonapi/changepass
Content-Type: application/json

{
    "email":"admin@gmail.com",
    "oldpassword":"vsk",
    "newpassword":"vskv"
}


### common logout 
GET http://localhost:3000/commonapi/logout


### get all articles by user
GET http://localhost:3000/userapi/article




### add comment by user
PUT http://localhost:3000/userapi/article
Content-Type: application/json

{
    "user":"6989676dd8451c7cda936194",
    "articleid":"69897343ed0e7043d1d3bbbd",
    "comment":"hey this is a comment"
}


### create author 
POST http://localhost:3000/authorapi/user
Content-Type: application/json

{
    "firstname":"rohi23th",
    "email":"suuusvwfw112geuu@gmail.com",
    "password":"1234er5ss",
    "profileimageurl":"http://youtube.com"

}


### create article 
POST http://localhost:3000/authorapi/article
Content-Type: application/json

{
    "author":"69ae835ce40aef8761073f50",
    "title":"rohhiihbvd",
    "content":"this is rohh reddy 2fgjwhfjwm"
}


### get all articles
GET http://localhost:3000/authorapi/article/69896b508a3e3c69c7ed3871


### update article
PUT http://localhost:3000/authorapi/article
Content-Type: application/json

{
    "author":"69896b508a3e3c69c7ed3871",
    "articleid":"69897343ed0e7043d1d3bbbd",
    "title":"james bond",
    "content":"story about james bond"
}


### soft delete article
Patch http://localhost:3000/authorapi/delarticle
Content-Type: application/json

{
    "author":"69897768ecbbf2baaf24fd05",
    "articleid":"698981f66e2ffa3403d36330"
}




### admin blocking user
PUT http://localhost:3000/adminapi/block/69897768ecbbf2baaf24fd05



### admin unblocking the user
PUT http://localhost:3000/adminapi/unblock/69897768ecbbf2baaf24fd05

